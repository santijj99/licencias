# Copiá este archivo a .env en el VPS:
#   cp .env.docker.example .env
#   nano .env

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Postgres (contenedor)
POSTGRES_DB=licencias
POSTGRES_USER=licencias
POSTGRES_PASSWORD=CAMBIAR_password_fuerte_db
POSTGRES_PUBLISH_PORT=5432

# API publicada en el host (luego nginx/SSL apunta acá)
LICENCIAS_PUBLISH_PORT=8080

# Mínimo 32+ caracteres
JWT_SECRET=CAMBIAR_jwt_secret_minimo_32_caracteres_seguros_aqui!!

# Exactamente 16, 24 o 32 bytes (caracteres). Debe coincidir con apirest (LICENCIA_AES_KEY).
AES_KEY=0123456789abcdef0123456789abcdef

# Orígenes del panel admin_licencias. Separados por coma (sin espacios de más).
# Desktop Windows no usa CORS; para Flutter web sí.
# Ejemplo: https://admin.tudominio.com,http://localhost:5000
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

JAVA_OPTS=-Xms128m -Xmx512m -XX:+UseG1GC
