# Desarrollo local (PostgreSQL instalado, como apirest):
# DB_USERNAME=postgres
# DB_PASSWORD=1234

# Docker compose (usuario del contenedor):
# DB_USERNAME=licencias
# DB_PASSWORD=licencias

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/licencias
DB_USERNAME=postgres
DB_PASSWORD=1234

JWT_SECRET=change-this-secret-key-must-be-at-least-256-bits-long-for-hs256!!
AES_KEY=0123456789abcdef0123456789abcdef

CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5000,http://localhost:5173
